{
  "name": "LiveSession",
  "type": "object",
  "properties": {
    "match_id": {
      "type": "string"
    },
    "match_title": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "paused",
        "ended"
      ],
      "default": "active"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "ended_at": {
      "type": "string",
      "format": "date-time"
    },
    "half_time": {
      "type": "number",
      "default": 1,
      "description": "Aktuelle Halbzeit: 1 oder 2. Wird f\u00fcr Seitenwechsel auf Kamera-Handy angezeigt."
    },
    "camera_streams": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "camera_id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "stream_url": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "last_seen": {
            "type": "string"
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "match_title"
  ]
}